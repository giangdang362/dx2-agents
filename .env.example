# ── Gemini Proxy ──────────────────────────────────────────────────────────────
# Required: your Google Gemini API key
GEMINI_API_KEY=''

# Optional: port the gemini proxy listens on (default: 4000)
# GEMINI_PROXY_PORT=4000

# ── OpenAI-compatible API ─────────────────────────────────────────────────────
# API key(s) for OpenAI-compatible providers.
# Use semicolons to separate multiple keys (matched 1:1 with BASE_URLS).
OPENAI_API_KEY=''
OPENAI_API_BASE_URL=''
OLLAMA_BASE_URL=''
# OPENAI_API_KEYS='key1;key2'

# Base URL(s) for the provider(s).  Defaults to https://api.openai.com/v1
# Use semicolons to separate multiple URLs (matched 1:1 with API_KEYS).
# OPENAI_API_BASE_URL='https://api.openai.com/v1'
# OPENAI_API_BASE_URLS='https://api.openai.com/v1;https://other-provider/v1'

# ── Open WebUI ────────────────────────────────────────────────────────────────
# Required in production: strong random string used to sign JWT session tokens.
# Generate one with: openssl rand -base64 32
WEBUI_SECRET_KEY=''

# Optional: host port to access the UI on (default: 3000)
# Maps to container port 8080.  Access via http://<server-ip>:3000
# OPEN_WEBUI_PORT=3000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Not needed in production (frontend and backend share the same origin).
# Only set this when running the Vite dev server separately.
# CORS_ALLOW_ORIGIN='http://localhost:5173;http://localhost:8080'
CORS_ALLOW_ORIGIN='*'

# ── Proxy / forwarding ────────────────────────────────────────────────────────
# For production behind a reverse proxy, set to the proxy IP (e.g. 127.0.0.1)
FORWARDED_ALLOW_IPS='*'

# ── Telemetry (opt-out) ───────────────────────────────────────────────────────
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false
